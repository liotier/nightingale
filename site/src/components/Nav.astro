---
---

<nav>
  <div class="nav-inner container">
    <a href="/" class="nav-brand">
      <img src="/logo_square.png" alt="Nightingale" height="28" />
      <span>Nightingale</span>
    </a>
    <button class="nav-toggle" aria-label="Toggle menu" hidden>
      <svg class="icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#how-it-works">How it works</a>
      <a href="/docs/">Docs</a>
      <a
        href="https://discord.gg/2s2XGSQQ"
        class="nav-icon"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Discord"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
      </a>
      <a
        href="https://github.com/rzru/nightingale/releases"
        class="nav-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Download
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle")!;
  const links = document.querySelector<HTMLDivElement>(".nav-links")!;

  toggle.addEventListener("click", () => {
    const open = links.classList.toggle("is-open");
    toggle.classList.toggle("is-open", open);
    toggle.setAttribute("aria-expanded", String(open));
  });

  links.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      links.classList.remove("is-open");
      toggle.classList.remove("is-open");
    });
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(19, 19, 30, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .nav-brand:hover {
    color: var(--text-primary);
  }

  .nav-brand img {
    height: 28px;
    width: 28px;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle svg {
    width: 22px;
    height: 22px;
  }

  .nav-toggle .icon-close {
    display: none;
  }

  .nav-toggle.is-open .icon-open {
    display: none;
  }

  .nav-toggle.is-open .icon-close {
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--text-secondary);
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .nav-icon {
    display: inline-flex;
    align-items: center;
    color: var(--text-secondary);
  }

  .nav-icon:hover {
    color: var(--text-primary);
  }

  .nav-icon svg {
    width: 20px;
    height: 20px;
  }

  .nav-cta {
    background: var(--accent);
    color: white !important;
    padding: 6px 16px;
    border-radius: var(--radius);
    font-weight: 500;
  }

  .nav-cta:hover {
    background: var(--accent-hover);
  }

  @media (max-width: 640px) {
    .nav-toggle[hidden] {
      display: block;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(19, 19, 30, 0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: 8px 0;
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links a {
      padding: 12px 24px;
      width: 100%;
    }

    .nav-cta {
      border-radius: 0;
      text-align: center;
    }
  }
</style>
